{
  "name": "pdf-builder",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:core": "cd packages/wasm && wasm-pack build --target web --out-dir pkg",
    "build:sdk": "cd packages/sdk && pnpm build",
    "build:playground": "cd packages/playground && pnpm build",
    "dev": "cd packages/playground && pnpm dev",
    "build": "turbo run build"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
